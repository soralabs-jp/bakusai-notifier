THREAD_URL=https://bakusai.com/thr_res/acode=3/ctgid=103/bid=566/tid=000000000/
WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# Optional
SERIES_NAME=
STATE_FILE=./data/state.json
HEADLESS=true
INITIAL_BOOT_NOTIFY=false
INCLUDE_POST_SNIPPETS=false
PLAYWRIGHT_TIMEOUT_MS=30000

# Fallback search URL used when the current thread page does not expose a "next thread" link.
# Replace {query} with the encoded series name.
BAKUSAI_SEARCH_URL_TEMPLATE=https://bakusai.com/sch_thr_thread/acode=0/word={query}/

# GitHub Actions can use the same values via repository secrets/environment variables.
# Example:
# DISCORD_WEBHOOK_URL=...
# BAKUSAI_THREAD_URL=...
